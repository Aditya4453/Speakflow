# MongoDB connection string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0

# Azure Blob Storage (for audio file persistence)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=speakflow-recordings

# Gemini API Key (optional — users can provide their own via the UI)
GEMINI_API_KEY=

# JWT Secret (change in production!)
JWT_SECRET=your-secret-key-here

# Additional CORS origins (comma-separated, optional)
CORS_ORIGINS=https://speakflow-jet.vercel.app
